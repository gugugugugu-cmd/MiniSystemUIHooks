<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="MiniSystemUIHooks&#10;&#10;修改后请重启 SystemUI 或重启手机。"
            android:textSize="16sp" />

        <!-- 隐藏锁屏状态栏 -->
        <CheckBox
            android:id="@+id/cbLockscreen"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="隐藏锁屏状态栏" />

        <!-- 隐藏 QS 运营商组 -->
        <CheckBox
            android:id="@+id/cbQsCarrier"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="隐藏 QS 运营商组" />

        <!-- 时钟大小功能 -->
        <CheckBox
            android:id="@+id/cbEnableClockSize"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="启用自定义状态栏时钟大小" />

        <TextView
            android:id="@+id/tvClockSizeTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="状态栏时钟大小"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tvClockSizeValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="14sp"
            android:textSize="20sp" />

        <LinearLayout
            android:id="@+id/layoutClockButtons"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnMinus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="-" />

            <Button
                android:id="@+id/btnPlus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="+" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>