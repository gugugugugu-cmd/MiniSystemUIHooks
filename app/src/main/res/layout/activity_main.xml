<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="MiniSystemUIHooks"
            android:textStyle="bold"
            android:textSize="20sp" />

        <TextView
            android:id="@+id/tvDesc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="修改后建议重启 SystemUI 或重启手机。"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvScope"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="LSPosed 推荐作用域：SystemUI（com.android.systemui）"
            android:textStyle="bold"
            android:textSize="14sp" />

        <CheckBox
            android:id="@+id/cbLockscreen"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="隐藏锁屏状态栏" />

        <CheckBox
            android:id="@+id/cbQsCarrier"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="隐藏 QS 运营商组" />

        <Button
            android:id="@+id/btnRestartSystemUI"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="重启 SystemUI" />

        <TextView
            android:id="@+id/tvHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="如果按钮无效，请手动重启 SystemUI 或直接重启手机。"
            android:textSize="13sp" />

    </LinearLayout>
</ScrollView>